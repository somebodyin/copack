# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram user IDs of the two admins allowed to use the bot,
# comma-separated. Ask @userinfobot for your numeric id.
ADMIN_IDS=123456789,987654321

# Optional display names shown in /start. Format: id:Name,id:Name
# ADMIN_NAMES=123456789:Alice,987654321:Bob
